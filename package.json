{
  "name": "papayamusic-lab-site",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "type": "module",
  "scripts": {
    "dev": "astro dev --host 127.0.0.1 --port 5182",
    "build": "astro build",
    "preview": "astro preview --host 127.0.0.1 --port 4182",
    "test": "node --test src/scripts/*.test.js contact-worker/test/*.test.js",
    "worker:test": "node --test contact-worker/test/*.test.js",
    "worker:check": "wrangler deploy --dry-run --config contact-worker/wrangler.jsonc --outdir .wrangler-dist",
    "worker:dev": "wrangler dev --config contact-worker/wrangler.jsonc",
    "worker:deploy": "wrangler deploy --config contact-worker/wrangler.jsonc"
  },
  "devDependencies": {
    "@lucide/astro": "^1.23.0",
    "astro": "^7.0.6",
    "pretendard": "^1.3.9",
    "sharp": "^0.35.3",
    "wrangler": "^4.0.0"
  }
}
