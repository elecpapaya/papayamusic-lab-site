---
import { BadgeCheck, HardDrive, History, ListChecks } from '@lucide/astro';
import { Picture } from 'astro:assets';
import SiteHeader from '../../components/SiteHeader.astro';
import heroProductionSuite from '../../assets/hero-production-suite-v2.png';
import { getBlogPosts } from '../../blog.js';
import { getHomeContent, languages } from '../../content.js';
import { languagePath } from '../../lib/paths.js';
import SiteLayout from '../../layouts/SiteLayout.astro';
import { siteConfig } from '../../siteConfig.js';

export function getStaticPaths() {
  return languages.map((item) => ({ params: { lang: item.code } }));
}

const { lang } = Astro.params;
const content = getHomeContent(lang);
const posts = await getBlogPosts(lang);
const previewPosts = posts.slice(0, 3);
const navItems = [
  [content.nav.features, '#features'],
  [content.nav.pilot, '#pilot'],
  [content.nav.blog, languagePath(lang, '/blog/')],
  [content.nav.docs, languagePath(lang, '/docs/')],
];
const positioningIcons = [ListChecks, History, HardDrive, BadgeCheck];
---

<SiteLayout
  title="PapayaMusic Lab"
  description={content.hero.lead}
  lang={lang}
  canonicalPath={`/${lang}/`}
  alternatePath="/"
>
  <SiteHeader
    brandSubtitle={content.brandSubtitle}
    currentLanguage={lang}
    currentPath="/"
    navItems={navItems}
  />

  <main id="main-content">
    <section class="hero">
      <Picture
        src={heroProductionSuite}
        formats={['avif', 'webp']}
        fallbackFormat="jpeg"
        widths={[640, 960, 1280, 1717]}
        sizes="100vw"
        alt=""
        class="hero-media-image"
        pictureAttributes={{ class: 'hero-media', 'aria-hidden': 'true' }}
        loading="eager"
        decoding="async"
        fetchpriority="high"
      />
      <div class="hero-copy">
        <p class="eyebrow">{content.hero.eyebrow}</p>
        <h1>{content.hero.title}</h1>
        <p class="lead">{content.hero.lead}</p>
        <div class="hero-actions">
          <a class="button primary" href={languagePath(lang, '/pilot/')}>{content.hero.primaryCta}</a>
          <a class="button secondary" href={languagePath(lang, '/blog/')}>{content.hero.secondaryCta}</a>
        </div>
      </div>
    </section>

    <section class="positioning-section home-plain" id="features">
      <div class="section-heading">
        <p class="eyebrow">{content.positioning.eyebrow}</p>
        <h2>{content.positioning.title}</h2>
        <p class="section-lead">{content.positioning.summary}</p>
      </div>
      <div class="positioning-principles">
        {
          content.positioning.cards.map((card, index) => {
            const Icon = positioningIcons[index];
            return (
            <article class="positioning-principle">
              <span class="principle-icon" aria-hidden="true">
                <Icon size={22} />
              </span>
              <div>
                <h3>{card.title}</h3>
                <p>{card.text}</p>
              </div>
            </article>
            );
          })
        }
      </div>
    </section>

    <section class="toolchain-section home-framed">
      <div class="toolchain-copy">
        <p class="eyebrow">{content.toolchain.eyebrow}</p>
        <h2>{content.toolchain.title}</h2>
        <p>{content.toolchain.text}</p>
      </div>
      <div class="toolchain-panel" aria-label={content.toolchain.title}>
        <div class="toolchain-strip">
          {content.toolchain.tools.map((tool) => <span>{tool}</span>)}
        </div>
        <p>{content.toolchain.note}</p>
      </div>
    </section>

    <section class="outcome-section home-plain">
      <div class="section-heading">
        <p class="eyebrow">{content.outcome.eyebrow}</p>
        <h2>{content.outcome.title}</h2>
      </div>
      <div class="outcome-grid">
        <div class="outcome-comparison">
          <div class="comparison-column muted-card">
            <span>{content.outcome.before.label}</span>
            <h3>{content.outcome.before.title}</h3>
            <ul>
              {content.outcome.before.facts.map((fact) => <li>{fact}</li>)}
            </ul>
          </div>
          <div class="comparison-column result-card">
            <span>{content.outcome.after.label}</span>
            <h3>{content.outcome.after.title}</h3>
            <ul>
              {content.outcome.after.facts.map((fact) => <li>{fact}</li>)}
            </ul>
          </div>
        </div>
        <article class="case-study-card">
          <h3>{content.caseStudy.title}</h3>
          <ul class="case-study-rows">
            {
              content.caseStudy.cards.map((card, index) => (
                <li>
                  <span>{String(index + 1).padStart(2, '0')}</span>
                  <strong>{card.metric}</strong>
                  <div>
                    <h4>{card.title}</h4>
                    <p>{card.text}</p>
                  </div>
                </li>
              ))
            }
          </ul>
        </article>
      </div>
    </section>

    <section class="band home-framed" id="pilot">
      <div class="section-heading">
        <p class="eyebrow">{content.pilot.eyebrow}</p>
        <h2>{content.pilot.title}</h2>
      </div>
      <div class="pilot-console">
        <article class="pilot-offer">
          <div>
            <span>{content.pilot.offer.label}</span>
            <h3>{content.pilot.offer.title}</h3>
            <dl class="pilot-offer-terms">
              {
                content.pilot.offer.terms.map((term) => (
                  <div>
                    <dt>{term.label}</dt>
                    <dd>{term.value}</dd>
                  </div>
                ))
              }
            </dl>
            <p>{content.pilot.offer.note}</p>
          </div>
          <div class="pilot-offer-includes">
            <span>{content.pilot.offer.itemsTitle}</span>
            <ul>
              {content.pilot.offer.items.map((item) => <li>{item}</li>)}
            </ul>
          </div>
        </article>
        <article class="pilot-detail-card">
          <div class="pilot-fit">
            <h3>{content.pilot.checklistTitle}</h3>
            <ul>
              {content.pilot.checklist.map((item) => <li>{item}</li>)}
            </ul>
          </div>
          <div class="pilot-detail-list">
            {
              content.pilot.cards.map((card) => (
                <div>
                  <h3>{card.title}</h3>
                  <p>{card.text}</p>
                </div>
              ))
            }
          </div>
        </article>
      </div>
      <div class="pilot-actions">
        <a class="button primary" href={languagePath(lang, '/pilot/')}>{content.pilot.requestCta}</a>
        <a class="pilot-payment-note" href={siteConfig.paymentUrl}>{content.pilot.paymentCta}</a>
      </div>
    </section>

    <section id="blog" class="content-section home-plain">
      <div class="section-heading compact-heading">
        <div>
          <p class="eyebrow">{content.blog.eyebrow}</p>
          <h2>{content.blog.title}</h2>
        </div>
        <a class="text-link section-top-link" href={languagePath(lang, '/blog/')}>{content.blog.allCta}</a>
      </div>
      <div class="post-grid">
        {
          previewPosts.map((post) => (
            <article class="post-card">
              <div class="post-meta">
                <span>{post.category}</span>
                <time datetime={post.date}>{post.date}</time>
              </div>
              <h3>{post.title}</h3>
              <p>{post.excerpt}</p>
              <a href={languagePath(lang, `/blog/${post.slug}/`)} aria-label={`${content.blog.readCta}: ${post.title}`}>
                {content.blog.readCta}
              </a>
            </article>
          ))
        }
      </div>
    </section>

  </main>
</SiteLayout>
