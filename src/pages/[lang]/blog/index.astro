---
import SiteHeader from '../../../components/SiteHeader.astro';
import { getBlogPosts } from '../../../blog.js';
import { getHomeContent, languages } from '../../../content.js';
import { languagePath } from '../../../lib/paths.js';
import SiteLayout from '../../../layouts/SiteLayout.astro';
import { getSalesContent } from '../../../salesContent.js';

export function getStaticPaths() {
  return languages.map((item) => ({ params: { lang: item.code } }));
}

const { lang } = Astro.params;
const content = getHomeContent(lang);
const sales = getSalesContent(lang);
const posts = await getBlogPosts(lang);
const categoryCounts = posts.reduce((counts, post) => {
  counts.set(post.category, (counts.get(post.category) ?? 0) + 1);
  return counts;
}, new Map());
const categories = Array.from(categoryCounts.entries());
const currentPath = '/blog/';
const navItems = [
  [sales.nav.tour, languagePath(lang, '/#product-tour')],
  [sales.nav.fit, languagePath(lang, '/#fit')],
  [sales.nav.pilot, languagePath(lang, '/#pilot')],
  [sales.nav.blog, languagePath(lang, '/blog/')],
  [sales.nav.docs, languagePath(lang, '/docs/')],
];
---

<SiteLayout
  title={content.blog.eyebrow}
  description={content.blog.title}
  lang={lang}
  canonicalPath={`/${lang}/blog/`}
  alternatePath="/blog/"
  designFamily="content"
>
  <SiteHeader
    brandSubtitle={content.blog.eyebrow}
    currentLanguage={lang}
    currentPath={currentPath}
    navItems={navItems}
    a11y={sales.a11y}
  />

  <main id="main-content">
    <section class="blog-index-hero">
      <div>
        <p class="eyebrow">{content.blog.eyebrow}</p>
        <h1>{content.blog.title}</h1>
        <p class="lead">{content.blog.introText}</p>
        <div class="hero-actions">
          <a class="button secondary" href={languagePath(lang, '/rss.xml')}>{content.blog.rssCta}</a>
          <a class="button secondary" href={languagePath(lang, '/')}>{content.brandSubtitle}</a>
        </div>
      </div>
      <aside class="blog-manager-panel" aria-label={content.blog.managerTitle}>
        <span>{content.blog.managerTitle}</span>
        <p>{content.blog.managerText}</p>
        <div class="blog-stats-strip">
          <span>{content.blog.sourceValue}</span>
          <span>{content.blog.postCountLabel} {posts.length}</span>
          <a href={languagePath(lang, '/rss.xml')}>RSS</a>
        </div>
      </aside>
    </section>

    <section class="content-section">
      <div class="section-heading compact-heading">
        <div>
          <p class="eyebrow">{content.blog.archiveTitle}</p>
        </div>
        <div class="category-strip">
          {categories.map(([category, count]) => <span>{category} · {count}</span>)}
        </div>
      </div>
      <div class="post-list">
        {
          posts.map((post, index) => (
            <article class:list={['post-row', index === 0 && 'is-featured']}>
              <div class="post-meta">
                <span class="post-category">{post.category}</span>
                {index === 0 && <span class="featured-badge">{content.blog.featuredLabel}</span>}
                <time datetime={post.date}>{post.date}</time>
              </div>
              <div>
                <h3>{post.title}</h3>
                <p>{post.excerpt}</p>
              </div>
              <a href={languagePath(lang, `/blog/${post.slug}/`)} aria-label={`${content.blog.readCta}: ${post.title}`}>
                {content.blog.readCta}
              </a>
            </article>
          ))
        }
      </div>
    </section>
  </main>
</SiteLayout>
