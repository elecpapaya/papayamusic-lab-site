---
import SiteHeader from '../../../components/SiteHeader.astro';
import { languages } from '../../../content.js';
import { languagePath } from '../../../lib/paths.js';
import SiteLayout from '../../../layouts/SiteLayout.astro';
import { getSalesContent } from '../../../salesContent.js';

export function getStaticPaths() {
  return languages.map((item) => ({ params: { lang: item.code } }));
}

const { lang } = Astro.params;
const sales = getSalesContent(lang);
const content = sales.dataHandling;
const currentPath = '/data-handling/';
const navItems = [
  [sales.nav.tour, languagePath(lang, '/#product-tour')],
  [sales.nav.fit, languagePath(lang, '/#fit')],
  [sales.nav.pilot, languagePath(lang, '/#pilot')],
  [sales.nav.faq, languagePath(lang, '/#faq')],
  [sales.nav.docs, languagePath(lang, '/docs/')],
];
---

<SiteLayout
  title={content.eyebrow}
  description={content.lead}
  lang={lang}
  canonicalPath={`/${lang}/data-handling/`}
  alternatePath="/data-handling/"
>
  <SiteHeader
    brandSubtitle={content.eyebrow}
    currentLanguage={lang}
    currentPath={currentPath}
    navItems={navItems}
    a11y={sales.a11y}
    compact
  />

  <main id="main-content" class="article-shell terms-shell">
    <p class="eyebrow">{content.eyebrow}</p>
    <h1>{content.title}</h1>
    <p class="lead">{content.lead}</p>
    <p class="terms-updated">{content.updated}</p>

    <div class="terms-list data-handling-list">
      {
        content.sections.map(([title, paragraphs]) => (
          <section class="terms-section">
            <h2>{title}</h2>
            <ul>{paragraphs.map((paragraph) => <li>{paragraph}</li>)}</ul>
          </section>
        ))
      }
    </div>

    <p><a class="button primary" href={languagePath(lang, '/contact/')}>{content.contactCta}</a></p>
  </main>
</SiteLayout>
