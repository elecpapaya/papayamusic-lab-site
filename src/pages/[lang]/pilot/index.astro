---
import SiteHeader from '../../../components/SiteHeader.astro';
import { ClipboardCopy, Mail } from '@lucide/astro';
import { getHomeContent, getPilotContent, getProtectedFormMessages, languages } from '../../../content.js';
import { languagePath } from '../../../lib/paths.js';
import SiteLayout from '../../../layouts/SiteLayout.astro';
import { siteConfig } from '../../../siteConfig.js';

export function getStaticPaths() {
  return languages.map((item) => ({ params: { lang: item.code } }));
}

const { lang } = Astro.params;
const content = getPilotContent(lang);
const formMessages = getProtectedFormMessages(lang);
const homeContent = getHomeContent(lang);
const fieldOrder = [
  'name',
  'email',
  'role',
  'operatingSystem',
  'catalogSize',
  'currentTools',
  'bottleneck',
  'goals',
  'notes',
];
const fieldSections = [
  {
    id: 'contact',
    fields: ['name', 'email', 'role', 'operatingSystem'],
  },
  {
    id: 'production',
    fields: ['catalogSize', 'currentTools'],
  },
  {
    id: 'outcome',
    fields: ['bottleneck', 'goals', 'notes'],
  },
];
const longFields = new Set(['bottleneck', 'goals', 'notes']);
const requiredFields = new Set(['name', 'email', 'bottleneck']);
const textareaRows = {
  bottleneck: 4,
  goals: 3,
  notes: 2,
};
const navItems = [
  [homeContent.nav.features, languagePath(lang, '/#features')],
  [homeContent.nav.pilot, languagePath(lang, '/#pilot')],
  [homeContent.nav.blog, languagePath(lang, '/blog/')],
  [homeContent.nav.docs, languagePath(lang, '/docs/')],
];
const autocomplete = {
  name: 'name',
  email: 'email',
  role: 'organization-title',
  operatingSystem: 'off',
  catalogSize: 'off',
  currentTools: 'off',
};
---

<SiteLayout
  title={content.eyebrow}
  description={content.lead}
  lang={lang}
  canonicalPath={`/${lang}/pilot/`}
  alternatePath="/pilot/"
>
  <SiteHeader
    brandSubtitle={content.brandSubtitle}
    currentLanguage={lang}
    currentPath="/pilot/"
    navItems={navItems}
    compact
  />

  <main id="main-content" class="pilot-shell">
    <section class="content-section pilot-hero">
      <p class="eyebrow">{content.eyebrow}</p>
      <h1>{content.title}</h1>
      <p class="lead">{content.lead}</p>
    </section>

    <section class="pilot-application-grid">
      <aside class="content-section pilot-guidance">
        <p class="privacy-note">{content.privacy}</p>
        <div class="pilot-info-grid">
          <article class="pilot-info-card">
            <h2>{content.fitTitle}</h2>
            <ul>
              {content.fitItems.map((item) => <li>{item}</li>)}
            </ul>
          </article>
          <article class="pilot-info-card">
            <h2>{content.reviewTitle}</h2>
            <ul>
              {content.reviewItems.map((item) => <li>{item}</li>)}
            </ul>
          </article>
          <article class="pilot-info-card">
            <h2>{content.afterTitle}</h2>
            <ul>
              {content.afterItems.map((item) => <li>{item}</li>)}
            </ul>
          </article>
        </div>
        <p>
          <a class="text-link" href={languagePath(lang, '/#pilot')}>{content.backCta}</a>
        </p>
      </aside>

      <form
        class="pilot-form"
        id="pilot-form"
        data-api-url={siteConfig.contactApiUrl}
        data-form-type="pilot"
        data-language={lang}
        data-fields={JSON.stringify(content.fields)}
        data-field-order={JSON.stringify(fieldOrder)}
        data-messages={JSON.stringify(formMessages)}
        data-summary-title={content.summaryTitle}
      >
        <div class="pilot-form-header">
          <p class="eyebrow">{content.formEyebrow}</p>
          <h2>{content.formTitle}</h2>
          <p>{content.formIntro}</p>
          <p class="privacy-note privacy-note-inline">{content.privacy}</p>
          <p class="form-required-note">{content.requiredNote}</p>
        </div>
        {
          fieldSections.map((section, index) => (
            <fieldset class="form-section">
              <legend>
                <small>{index + 1} / {fieldSections.length}</small>
                <span>
                  <strong>{content.formSections[section.id].title}</strong>
                  <span>{content.formSections[section.id].text}</span>
                </span>
              </legend>
              <div class="form-section-grid">
                {section.fields.map((name) => (
                  <label class:list={[
                    'form-field',
                    `field-${name}`,
                    longFields.has(name) && 'form-field-wide',
                    requiredFields.has(name) ? 'is-required' : 'is-optional',
                  ]}>
                    <span>
                      {content.fields[name]}
                      {requiredFields.has(name) && <em>{content.requiredLabel}</em>}
                    </span>
                    {
                      longFields.has(name) ? (
                        <textarea name={name} rows={textareaRows[name] ?? 3} placeholder={content.placeholders[name]} required={requiredFields.has(name)}></textarea>
                      ) : (
                        <input
                          type={name === 'email' ? 'email' : 'text'}
                          name={name}
                          placeholder={content.placeholders[name]}
                          autocomplete={autocomplete[name] ?? 'off'}
                          required={requiredFields.has(name)}
                        />
                      )
                    }
                  </label>
                ))}
              </div>
            </fieldset>
          ))
        }
        <label class="form-honeypot" aria-hidden="true">
          <span>Website</span>
          <input name="website" type="text" tabindex="-1" autocomplete="off" />
        </label>
        <input name="startedAt" type="hidden" value="" />
        <div class="turnstile-row">
          <div data-turnstile></div>
          <p>{content.privacy}</p>
        </div>
        <div class="pilot-form-actions">
          <button class="button primary" type="submit" data-submit disabled><Mail size={16} />{content.submitCta}</button>
          <button class="button secondary" type="button" data-copy><ClipboardCopy size={16} />{content.copyCta}</button>
        </div>
        <output class="form-output" data-output aria-live="polite"></output>
      </form>
    </section>
  </main>

  <script>
    import { setupProtectedForm } from '../../../scripts/protectedForm.js';

    setupProtectedForm('#pilot-form');
  </script>
</SiteLayout>
