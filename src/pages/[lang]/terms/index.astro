---
import SiteHeader from '../../../components/SiteHeader.astro';
import { languages, termsContent } from '../../../content.js';
import { languagePath } from '../../../lib/paths.js';
import SiteLayout from '../../../layouts/SiteLayout.astro';
import { getSalesContent } from '../../../salesContent.js';

export function getStaticPaths() {
  return languages.map((item) => ({ params: { lang: item.code } }));
}

const { lang } = Astro.params;
const terms = termsContent[lang] ?? termsContent.en;
const sales = getSalesContent(lang);
const currentPath = '/terms/';
const navItems = [
  [sales.nav.tour, languagePath(lang, '/#product-tour')],
  [sales.nav.fit, languagePath(lang, '/#fit')],
  [sales.nav.pilot, languagePath(lang, '/#pilot')],
  [sales.nav.faq, languagePath(lang, '/#faq')],
  [sales.nav.docs, languagePath(lang, '/docs/')],
];
---

<SiteLayout
  title={terms.eyebrow}
  description={terms.lead}
  lang={lang}
  canonicalPath={`/${lang}/terms/`}
  alternatePath="/terms/"
  designFamily="content"
>
  <SiteHeader
    brandSubtitle={terms.brandSubtitle}
    currentLanguage={lang}
    currentPath={currentPath}
    navItems={navItems}
    a11y={sales.a11y}
    compact
  />

  <main id="main-content" class="article-shell terms-shell">
    <p class="eyebrow">{terms.eyebrow}</p>
    <h1>{terms.title}</h1>
    <p class="lead">{terms.lead}</p>
    <p class="terms-updated">{terms.updated}</p>

    <div class="terms-list">
      {
        terms.sections.map((section) => (
          <section class="terms-section">
            <h2>{section.title}</h2>
            {section.paragraphs.map((paragraph) => (
              <p>{paragraph}</p>
            ))}
          </section>
        ))
      }
    </div>
  </main>
</SiteLayout>
