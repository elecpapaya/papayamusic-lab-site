---
import 'pretendard/dist/web/variable/pretendardvariable-dynamic-subset.css';
import '../styles.css';
import { getHomeContent, languages } from '../content.js';
import { languagePath } from '../lib/paths.js';
import { getSalesContent } from '../salesContent.js';
import { siteConfig } from '../siteConfig.js';

const {
  title = 'PapayaMusic Lab',
  description = 'Local-first production control room for AI-native music catalogs.',
  lang = 'en',
  canonicalPath = `/${lang}/`,
  alternatePath = null,
  type = 'website',
  noindex = false,
  softwareApplication = false,
  publishedTime = null,
  modifiedTime = null,
  articleSection = null,
  faqItems = [],
  designFamily = 'content',
} = Astro.props;
const pageTitle = title === 'PapayaMusic Lab' ? title : `${title} | PapayaMusic Lab`;
const layoutContent = getHomeContent(lang);
const salesContent = getSalesContent(lang);
const siteUrl = siteConfig.siteUrl.replace(/\/$/, '');
const canonicalUrl = `${siteUrl}${canonicalPath}`;
const imageUrl = `${siteUrl}${siteConfig.ogImagePath}`;
const rssUrl = `${siteUrl}/${lang}/rss.xml`;
const assetBase = import.meta.env.BASE_URL.replace(/\/$/, '');
const assetPath = (path) => `${assetBase}${path}`;
const alternateLinks = alternatePath
  ? languages.map((item) => ({
      language: item.htmlLang,
      href: `${siteUrl}/${item.code}${alternatePath}`,
    }))
  : [];
const structuredEntries = [
  {
    '@type': 'Organization',
    '@id': `${siteUrl}/#organization`,
    name: 'PapayaMusic Lab',
    url: siteUrl,
    logo: `${siteUrl}/apple-touch-icon.png`,
  },
];

if (softwareApplication) {
  structuredEntries.push({
    '@type': 'SoftwareApplication',
    '@id': `${siteUrl}/#software`,
    name: salesContent.productName,
    applicationCategory: 'MultimediaApplication',
    operatingSystem: 'Windows',
    description,
    url: canonicalUrl,
    author: { '@id': `${siteUrl}/#organization` },
  });
}

if (type === 'article') {
  structuredEntries.push({
    '@type': 'Article',
    '@id': `${canonicalUrl}#article`,
    headline: title,
    description,
    datePublished: publishedTime || undefined,
    dateModified: modifiedTime || publishedTime || undefined,
    articleSection: articleSection || undefined,
    inLanguage: lang,
    mainEntityOfPage: canonicalUrl,
    author: { '@id': `${siteUrl}/#organization` },
    publisher: { '@id': `${siteUrl}/#organization` },
    image: imageUrl,
  });
}

if (faqItems.length > 0) {
  structuredEntries.push({
    '@type': 'FAQPage',
    '@id': `${canonicalUrl}#faq`,
    mainEntity: faqItems.map(([question, answer]) => ({
      '@type': 'Question',
      name: question,
      acceptedAnswer: {
        '@type': 'Answer',
        text: answer,
      },
    })),
  });
}

const structuredData = JSON.stringify({
  '@context': 'https://schema.org',
  '@graph': structuredEntries,
}).replace(/</g, '\\u003c');
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="copyright" content={layoutContent.footer.copyright} />
    <meta name="theme-color" content="oklch(14% 0.014 42)" />
    <link rel="icon" href={assetPath('/favicon.svg')} type="image/svg+xml" />
    <link rel="apple-touch-icon" href={assetPath('/apple-touch-icon.png')} />
    <link rel="alternate" type="application/rss+xml" title="PapayaMusic Lab Blog" href={rssUrl} />
    {noindex && <meta name="robots" content="noindex,follow" />}
    <link rel="canonical" href={canonicalUrl} />
    {
      alternateLinks.map((item) => (
        <link rel="alternate" hreflang={item.language} href={item.href} />
      ))
    }
    {alternatePath && <link rel="alternate" hreflang="x-default" href={`${siteUrl}/en${alternatePath}`} />}
    <meta property="og:site_name" content="PapayaMusic Lab" />
    <meta property="og:type" content={type} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={imageUrl} />
    <meta property="og:image:alt" content="PapayaMusic Lab production control room preview" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    {publishedTime && <meta property="article:published_time" content={publishedTime} />}
    {modifiedTime && <meta property="article:modified_time" content={modifiedTime} />}
    {articleSection && <meta property="article:section" content={articleSection} />}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={imageUrl} />
    <script type="application/ld+json" set:html={structuredData}></script>
    <title>{pageTitle}</title>
  </head>
  <body data-event-endpoint={siteConfig.contactApiUrl} data-design-family={designFamily}>
    <a class="skip-link" href="#main-content">{layoutContent.skipLink}</a>
    <slot />
    <footer class="site-footer foot-stmt">
      <p class="footer-statement">{salesContent.footer.description}</p>
      <div class="footer-meta">
        <div class="footer-identity">
          <strong>PapayaMusic Lab</strong>
          <p>{layoutContent.footer.copyright}</p>
          <p>{salesContent.footer.notice}</p>
        </div>
        <nav aria-label={salesContent.a11y.footerNav}>
          <a href={languagePath(lang, '/data-handling/')}>{salesContent.footer.data}</a>
          <a href={languagePath(lang, '/terms/')}>{salesContent.footer.terms}</a>
          <a href={languagePath(lang, '/docs/')}>{salesContent.footer.docs}</a>
          <a href={languagePath(lang, siteConfig.contactPath)}>{salesContent.footer.contact}</a>
        </nav>
      </div>
    </footer>
    <script>
      import { setupFunnelAnalytics } from '../scripts/funnelAnalytics.js';

      setupFunnelAnalytics();
    </script>
  </body>
</html>
