---
import 'pretendard/dist/web/variable/pretendardvariable-dynamic-subset.css';
import '../styles.css';
import { getHomeContent, languages } from '../content.js';
import { languagePath } from '../lib/paths.js';
import { siteConfig } from '../siteConfig.js';

const {
  title = 'PapayaMusic Lab',
  description = 'Local-first production control room for AI-native music catalogs.',
  lang = 'en',
  canonicalPath = `/${lang}/`,
  alternatePath = null,
  type = 'website',
  noindex = false,
} = Astro.props;
const pageTitle = title === 'PapayaMusic Lab' ? title : `${title} | PapayaMusic Lab`;
const layoutContent = getHomeContent(lang);
const siteUrl = siteConfig.siteUrl.replace(/\/$/, '');
const canonicalUrl = `${siteUrl}${canonicalPath}`;
const imageUrl = `${siteUrl}${siteConfig.ogImagePath}`;
const rssUrl = `${siteUrl}/${lang}/rss.xml`;
const assetBase = import.meta.env.BASE_URL.replace(/\/$/, '');
const assetPath = (path) => `${assetBase}${path}`;
const alternateLinks = alternatePath
  ? languages.map((item) => ({
      language: item.htmlLang,
      href: `${siteUrl}/${item.code}${alternatePath}`,
    }))
  : [];
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="copyright" content={layoutContent.footer.copyright} />
    <meta name="theme-color" content="#ecebe5" />
    <link rel="icon" href={assetPath('/favicon.svg')} type="image/svg+xml" />
    <link rel="apple-touch-icon" href={assetPath('/apple-touch-icon.png')} />
    <link rel="alternate" type="application/rss+xml" title="PapayaMusic Lab Blog" href={rssUrl} />
    {noindex && <meta name="robots" content="noindex,follow" />}
    <link rel="canonical" href={canonicalUrl} />
    {
      alternateLinks.map((item) => (
        <link rel="alternate" hreflang={item.language} href={item.href} />
      ))
    }
    {alternatePath && <link rel="alternate" hreflang="x-default" href={`${siteUrl}/en${alternatePath}`} />}
    <meta property="og:site_name" content="PapayaMusic Lab" />
    <meta property="og:type" content={type} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={imageUrl} />
    <meta property="og:image:alt" content="PapayaMusic Lab production control room preview" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={imageUrl} />
    <title>{pageTitle}</title>
  </head>
  <body>
    <a class="skip-link" href="#main-content">{layoutContent.skipLink}</a>
    <slot />
    <footer class="site-footer">
      <div>
        <strong>PapayaMusic Lab</strong>
        <p>{layoutContent.footer.copyright}</p>
        <p>{layoutContent.footer.notice}</p>
      </div>
      <nav aria-label="Footer navigation">
        <a href={languagePath(lang, '/terms/')}>{layoutContent.footer.terms}</a>
        <a href={languagePath(lang, siteConfig.contactPath)}>{layoutContent.footer.contact}</a>
      </nav>
    </footer>
  </body>
</html>
