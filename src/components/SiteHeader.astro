---
import { languages } from '../content.js';
import { languagePath } from '../lib/paths.js';

const {
  brandSubtitle,
  currentLanguage = 'en',
  currentPath = '/',
  navItems = [],
  compact = false,
  a11y = {},
} = Astro.props;

const labels = {
  home: a11y.home || 'PapayaMusic Lab home',
  primaryNav: a11y.primaryNav || 'Primary navigation',
  language: a11y.language || 'Language selector',
};
---

<header class:list={['site-header', compact && 'article-header']}>
  <a class="brand" href={languagePath(currentLanguage, '/')} aria-label={labels.home}>
    <span class="brand-mark">P</span>
    <span>
      <strong>PapayaMusic Lab</strong>
      <small>{brandSubtitle}</small>
    </span>
  </a>
  <div class="header-actions">
    {
      navItems.length > 0 && (
        <nav aria-label={labels.primaryNav}>
          {
            navItems.map(([label, href]) => {
              const isCurrent = href === languagePath(currentLanguage, currentPath);
              return (
                <a href={href} aria-current={isCurrent ? 'page' : undefined}>
                  {label}
                </a>
              );
            })
          }
        </nav>
      )
    }
    <div class="language-switch" aria-label={labels.language}>
      {
        languages.map((item) => (
          <a
            href={languagePath(item.code, currentPath)}
            aria-current={item.code === currentLanguage ? 'true' : undefined}
            aria-label={item.name}
          >
            {item.label}
          </a>
        ))
      }
    </div>
  </div>
</header>
