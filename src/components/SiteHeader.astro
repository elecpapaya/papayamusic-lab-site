---
import { languages } from '../content.js';
import { languagePath } from '../lib/paths.js';
import { getSalesContent } from '../salesContent.js';

const {
  brandSubtitle,
  currentLanguage = 'en',
  currentPath = '/',
  navItems = [],
  compact = false,
  a11y = {},
} = Astro.props;

const labels = {
  home: a11y.home || 'PapayaMusic Lab home',
  primaryNav: a11y.primaryNav || 'Primary navigation',
  language: a11y.language || 'Language selector',
};
const sales = getSalesContent(currentLanguage);
const primaryItem = navItems.find(([, href]) => href.endsWith('#pilot'))
  ?? [sales.nav.pilot, languagePath(currentLanguage, '/#pilot')];
---

<header class:list={['site-header', compact && 'article-header']}>
  <div class="brand-lockup">
    <a class="brand wordmark" href={languagePath(currentLanguage, '/')} aria-label={labels.home}>
      <strong>PapayaMusic Lab</strong>
    </a>
    <small>{brandSubtitle}</small>
  </div>
  <div class="header-actions">
    <div class="language-switch" aria-label={labels.language}>
      {
        languages.map((item) => (
          <a
            href={languagePath(item.code, currentPath)}
            aria-current={item.code === currentLanguage ? 'true' : undefined}
            aria-label={item.name}
          >
            {item.label}
          </a>
        ))
      }
    </div>
    {
      primaryItem && (
        <nav class="edge-primary-action" aria-label={labels.primaryNav}>
          <a
            class="header-cta"
            href={primaryItem[1]}
            aria-current={primaryItem[1] === languagePath(currentLanguage, currentPath) ? 'page' : undefined}
          >
            {primaryItem[0]}
          </a>
        </nav>
      )
    }
  </div>
</header>
